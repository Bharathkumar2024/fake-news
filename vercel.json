{
  "outputDirectory": "web_app/html",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/web_app/html/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 2048,
      "maxDuration": 30
    }
  },
  "env": {
    "FLASK_ENV": "production",
    "PYTHONIOENCODING": "utf-8"
  }
}
