{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": "web_app/html",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/web_app/backend/app.py"
    },
    {
      "source": "/(.*)",
      "destination": "/web_app/html/index.html"
    }
  ],
  "functions": {
    "web_app/backend/app.py": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "env": {
    "FLASK_ENV": "production"
  }
}
